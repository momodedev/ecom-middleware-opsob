# OceanBase Cluster Inventory Template
# Copy this file to `inventory/oceanbase_hosts` and update with actual values

[oceanbase]
{% for index in range(0, oceanbase_instance_count) %}
ob-observer-{{ index }} ansible_host={{ observer_private_ips[index] }} private_ip={{ observer_private_ips[index] }}
{% endfor %}

[oceanbase:vars]
ansible_user=oceanadmin
ansible_ssh_private_key_file=~/.ssh/id_ed25519
ansible_python_interpreter=/usr/bin/python3
oceanbase_cluster_name={{ oceanbase_cluster_name }}
oceanbase_root_password={{ oceanbase_root_password }}
oceanbase_memory_limit={{ oceanbase_memory_limit }}
oceanbase_cpu_count={{ oceanbase_cpu_count }}
oceanbase_mysql_port={{ oceanbase_mysql_port }}
oceanbase_rpc_port=2882
oceanbase_obshell_port=2886
