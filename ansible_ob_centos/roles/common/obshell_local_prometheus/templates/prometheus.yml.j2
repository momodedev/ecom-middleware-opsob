global:
  scrape_interval: 1s
  evaluation_interval: 10s

rule_files:
  - "{{ obshell_local_prometheus_rules_dir }}/host_rules.yaml"
  - "{{ obshell_local_prometheus_rules_dir }}/ob_rules.yaml"

scrape_configs:
  - job_name: prometheus
    metrics_path: /metrics
    static_configs:
      - targets:
          - '{{ obshell_local_prometheus_listen_address }}'

  - job_name: node
    metrics_path: /metrics/node/host
    static_configs:
      - targets:
          - '{{ obshell_local_prometheus_target }}'

  - job_name: ob_basic
    metrics_path: /metrics/ob/basic
    static_configs:
      - targets:
          - '{{ obshell_local_prometheus_target }}'

  - job_name: ob_extra
    metrics_path: /metrics/ob/extra
    static_configs:
      - targets:
          - '{{ obshell_local_prometheus_target }}'

  - job_name: agent
    metrics_path: /metrics/stat
    static_configs:
      - targets:
          - '{{ obshell_local_prometheus_target }}'
