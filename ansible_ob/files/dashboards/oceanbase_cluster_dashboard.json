        "tooltip": { "mode": "multi", "sort": "desc" },
        "thresholds": {
          "mode": "line+area",
          "steps": [
            { "color": "transparent", "value": null },
            { "color": "super-light-orange", "value": 80 }
          ]
        }
      },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\", job=~\"node.*\"}[$__rate_interval])) * 100)",
