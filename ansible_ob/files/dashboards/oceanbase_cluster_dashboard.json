      "id": 7,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "max((1 - node_filesystem_avail_bytes{mountpoint=\"/oceanbase/redo\", job=~\"node.*\"} / node_filesystem_size_bytes{mountpoint=\"/oceanbase/redo\", job=~\"node.*\"}) * 100)",
          "legendFormat": "Log Disk %",
          "refId": "A"
        }
      ],
      "title": "Log Disk Usage %  [⚠ >70% = Alert 1]",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "max": 100,
          "min": 0,
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 8,
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
