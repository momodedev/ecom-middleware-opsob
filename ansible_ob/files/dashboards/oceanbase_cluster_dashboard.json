          "refId": "A"
        }
      ],
      "title": "CPU Usage % by Host  [alert threshold: 80%]",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
