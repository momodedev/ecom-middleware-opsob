          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "definition": "label_values(ob_memstore_percent{job=~\"oceanbase.*\"}, tenant_name)",
        "hide": 0,
        "includeAll": true,
        "label": "Tenant",
        "multi": false,
        "name": "tenant",
        "options": [],
        "query": {
          "query": "label_values(ob_memstore_percent{job=~\"oceanbase.*\"}, tenant_name)",
