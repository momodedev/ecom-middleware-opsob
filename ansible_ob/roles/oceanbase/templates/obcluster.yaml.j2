---
# OceanBase cluster configuration template
# Generated by Ansible

user:
  username: {{ oceanbase_admin_user }}
  key_file: {{ oceanbase_admin_home }}/.ssh/id_rsa
  port: {{ oceanbase_ssh_port }}

{{ oceanbase_obd_component }}:
{% if oceanbase_obd_version | default('') | length > 0 %}
  version: {{ oceanbase_obd_version }}
{% endif %}
  servers:
{% for host in groups['oceanbase'] %}
    - name: {{ host }}
      ip: {{ hostvars[host]['private_ip'] | default(hostvars[host]['ansible_host']) }}
{% endfor %}
  global:
    # Cluster basic configuration
    cluster_id: 1
    memory_limit: {{ oceanbase_memory_limit }}
    system_memory: 4G
    stack_size: 512K
    cpu_count: {{ oceanbase_cpu_count }}
    cache_wash_threshold: 1G
    __min_full_resource_pool_memory: 1073741824
    workers_per_cpu_quota: 10
    schema_history_expire_time: 1d
    
    # Network configuration
    devname: eth0
    mysql_port: 2881
    rpc_port: 2882
    obshell_port: 2886
    
    # Storage configuration
    datafile_size: {{ (oceanbase_datafile_size_gb_no_data_disk if (oceanbase_skip_data_mount | bool) else oceanbase_datafile_size_gb) }}G
    datafile_next: 1G
    datafile_maxsize: {{ (oceanbase_datafile_maxsize_gb_no_data_disk if (oceanbase_skip_data_mount | bool) else oceanbase_datafile_maxsize_gb) }}G
    log_disk_size: {{ (oceanbase_log_disk_size_gb_no_data_disk if (oceanbase_skip_data_mount | bool) else oceanbase_log_disk_size_gb) }}G
    
    # Syslog configuration
    enable_syslog_recycle: true
    max_syslog_file_count: 4
    syslog_level: INFO
    
    # Production mode (set to false for testing)
    production_mode: false
    enable_syslog_wf: false
    
    # Root password
    root_password: {{ oceanbase_root_password }}
    
{% for host in groups['oceanbase'] %}
  {{ host }}:
    mysql_port: 2881
    rpc_port: 2882
    obshell_port: 2886
    home_path: /oceanbase/server
    data_dir: /oceanbase/data
    redo_dir: /oceanbase/redo
    zone: zone{{ loop.index }}
{% endfor %}
