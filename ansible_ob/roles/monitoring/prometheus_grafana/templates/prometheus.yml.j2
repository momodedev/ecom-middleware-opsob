global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - /etc/prometheus/rules/*.yml

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets:
          - 'localhost:9090'

  - job_name: 'oceanbase-basic'
    metrics_path: /metrics/ob/basic
    file_sd_configs:
      - files:
          - '/etc/prometheus/file_sd/oceanbase_targets.json'
        refresh_interval: 30s

  - job_name: 'oceanbase-extra'
    metrics_path: /metrics/ob/extra
    file_sd_configs:
      - files:
          - '/etc/prometheus/file_sd/oceanbase_targets.json'
        refresh_interval: 30s

  - job_name: 'oceanbase-agent'
    metrics_path: /metrics/stat
    file_sd_configs:
      - files:
          - '/etc/prometheus/file_sd/oceanbase_targets.json'
        refresh_interval: 30s

  - job_name: 'node-exporter'
    file_sd_configs:
      - files:
          - '/etc/prometheus/file_sd/node_targets.json'
        refresh_interval: 30s
